# Copy to .env and fill in only what you need. The app defaults to the stub
# backend, so it runs with NO keys at all.

# Which vision backend to use: stub | anthropic | gemini | openai | local
VISION_BACKEND=stub

# --- Anthropic (Claude Haiku 4.5) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Google Gemini ---
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Local OpenAI-compatible endpoint (Ollama / vLLM) ---
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL=qwen2-vl:2b
# LOCAL_API_KEY=ollama

# --- Tuning (all optional; sensible defaults in config.py) ---
# VISION_MAX_EDGE=768
# SHARP_BLUR_FLOOR=40
# SHARP_OK=150
# DUP_DISTANCE=5
# UNIQUE_DISTANCE=12
# MEETING_PLAUSIBILITY_GATE=30
# BAND_CLEAR=70
# BAND_DOUBTFUL=40

# Approx cost per photo (USD) shown in the bake-off table.
# COST_ANTHROPIC=0.0020
# COST_GEMINI=0.0004
# COST_OPENAI=0.0015
