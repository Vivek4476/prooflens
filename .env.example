# ProofLens configuration — copy to .env and edit. Secrets ONLY via env, never code.
# Every value here has a sane default in src/prooflens/config.py; the app runs
# out of the box with the stub backend and no secrets.

# ---- Core ----
PROOFLENS_ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO

# ---- Database (Postgres does triple duty: tenants, queue, hash store, results) ----
# Only required to run the api/worker; the pure engine + CLI + golden tests do not need it.
DATABASE_URL=postgresql+psycopg://prooflens:prooflens@localhost:5432/prooflens

# ---- Encryption ----
# Fernet key used to encrypt per-tenant LSQ credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in staging/prod. In dev a fixed dev key is used if unset.
PROOFLENS_SECRET_KEY=

# ---- Vision backend (default = stub: zero network, zero keys) ----
VISION_BACKEND=stub          # stub | gemini | openrouter | nvidia | anthropic | local_vlm
VISION_MAX_EDGE=768                     # long-edge px before the vision call

# gemini backend — free tier at https://aistudio.google.com (just a Google account)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# openrouter backend — free ":free" vision models at https://openrouter.ai
# other free options: google/gemma-4-31b-it:free, google/gemma-4-26b-a4b-it:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# nvidia backend — free hosted VLMs at https://build.nvidia.com (key = nvapi-...)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.2-90b-vision-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# anthropic backend (do not set unless you intend to spend)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# local_vlm backend (any OpenAI-compatible endpoint, e.g. Ollama/vLLM)
LOCAL_VLM_BASE_URL=http://localhost:11434/v1
LOCAL_VLM_MODEL=qwen2-vl:7b
LOCAL_VLM_API_KEY=not-needed

# ---- Queue / worker ----
QUEUE_MAX_ATTEMPTS=5                     # attempts before dead-letter
QUEUE_BACKOFF_BASE_SECONDS=5            # exponential backoff base
QUEUE_BACKOFF_MAX_SECONDS=900          # backoff ceiling
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=5
